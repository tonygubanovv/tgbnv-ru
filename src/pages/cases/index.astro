---
import BaseLayout from '@layouts/BaseLayout.astro';
import Card from '@components/Card.astro';
import { getCollection } from 'astro:content';
import { byDateDesc, entrySlug, visibleEntry } from '@lib/content';

const cases = (await getCollection('cases')).filter(visibleEntry).sort(byDateDesc);
---

<BaseLayout title="Кейсы" description="Кейсы с задачами, решениями, результатами и выводами.">
  <section class="container section">
    <p class="eyebrow">Практика</p>
    <h1 class="page-title">Кейсы</h1>
    <p class="lead">Формат: контекст, задача, решение, результат и что можно повторить в похожей ситуации.</p>
    <div class="grid two listing">
      {cases.map((entry) => (
        <Card href={`/cases/${entrySlug(entry)}/`} title={entry.data.title} description={entry.data.description} date={entry.data.pubDate} result={entry.data.result} tags={entry.data.tags} />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .listing {
    margin-top: 32px;
  }
</style>
