---
import BaseLayout from '@layouts/BaseLayout.astro';
import Card from '@components/Card.astro';
import { getCollection } from 'astro:content';
import { byDateDesc, entrySlug, visibleEntry } from '@lib/content';

const cases = (await getCollection('cases')).filter(visibleEntry).sort(byDateDesc).slice(0, 3);
const posts = (await getCollection('blog')).filter(visibleEntry).sort(byDateDesc).slice(0, 3);
---

<BaseLayout title="Главная" description="Персональный сайт Тони Губанова: кейсы, статьи, услуги и карьерный опыт.">
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">AI, аналитика, автоматизация</p>
        <h1 class="page-title">Помогаю превращать сложные процессы в понятные цифровые системы.</h1>
        <p class="lead">
          Здесь будут кейсы, статьи и услуги: от аналитики и продуктовой упаковки до внедрения AI-инструментов в реальные рабочие процессы.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/cases/">Смотреть кейсы</a>
          <a class="button secondary" href="/services/">Услуги</a>
        </div>
      </div>
      <div class="hero-panel" aria-label="Ключевые направления">
        <div>
          <span>01</span>
          <strong>Кейсы вместо обещаний</strong>
          <p>Задача, решение, результат и выводы без маркетинговой воды.</p>
        </div>
        <div>
          <span>02</span>
          <strong>Статьи с практикой</strong>
          <p>Материалы, которые можно дублировать в Telegram и развивать в контентную базу.</p>
        </div>
        <div>
          <span>03</span>
          <strong>Услуги понятно</strong>
          <p>Несколько конкретных направлений, понятные ожидания и быстрый контакт.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Публикации</p>
          <h2>Свежие кейсы и статьи</h2>
        </div>
        <a class="button secondary" href="/blog/">Все статьи</a>
      </div>
      <div class="grid three">
        {[...cases, ...posts].slice(0, 3).map((entry) => (
          <Card
            href={`/${entry.collection === 'cases' ? 'cases' : 'blog'}/${entrySlug(entry)}/`}
            title={entry.data.title}
            description={entry.data.description}
            date={entry.data.pubDate}
            result={'result' in entry.data ? entry.data.result : undefined}
            tags={entry.data.tags}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: var(--color-dark);
    color: var(--color-inverse);
    padding-block: 72px;
  }

  .hero .lead {
    color: rgba(255, 255, 255, 0.72);
  }

  .hero-grid {
    align-items: center;
    display: grid;
    gap: 48px;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .hero-panel {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 24px;
  }

  .hero-panel div + div {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    margin-top: 18px;
    padding-top: 18px;
  }

  .hero-panel span {
    color: var(--color-brand-soft);
    font-family: var(--font-code);
    font-size: 12px;
  }

  .hero-panel strong {
    display: block;
    margin-top: 8px;
  }

  .hero-panel p {
    color: rgba(255, 255, 255, 0.68);
    margin: 8px 0 0;
  }

  .section-head {
    align-items: end;
    display: flex;
    gap: 24px;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .section-head h2 {
    font-size: 28px;
    line-height: 1.25;
    margin: 0;
  }

  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .section-head {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
