---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

const headings = (Astro.props.headings ?? []).filter((heading: Heading) => heading.depth === 2 || heading.depth === 3);
---

{headings.length > 0 && (
  <aside class="toc" aria-label="Содержание">
    <p>Содержание</p>
    <nav>
      {headings.map((heading: Heading) => (
        <a class={`depth-${heading.depth}`} href={`#${heading.slug}`}>{heading.text}</a>
      ))}
    </nav>
  </aside>
)}

<style>
  .toc {
    border-left: 1px solid var(--color-border);
    padding-left: 16px;
    position: sticky;
    top: 92px;
  }

  .toc p {
    color: var(--color-text);
    font-size: 12px;
    font-weight: 600;
    margin: 0 0 10px;
  }

  .toc nav {
    display: grid;
    gap: 8px;
  }

  .toc a {
    color: var(--color-text-muted);
    font-size: 13px;
    line-height: 1.35;
    text-decoration: none;
  }

  .toc a.depth-3 {
    padding-left: 12px;
  }

  @media (max-width: 980px) {
    .toc {
      border-left: 0;
      border-top: 1px solid var(--color-border);
      padding: 16px 0 0;
      position: static;
    }
  }
</style>
