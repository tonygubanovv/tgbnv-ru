---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="metric">
  <strong>{value}</strong>
  <span>{label}</span>
</div>

<style>
  .metric {
    background: var(--color-surface-soft);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    margin: 16px 0;
    padding: 16px;
  }

  strong {
    color: var(--color-brand);
    display: block;
    font-size: 28px;
    font-weight: 600;
    line-height: 1.2;
  }

  span {
    color: var(--color-text-muted);
    display: block;
    margin-top: 4px;
  }
</style>
